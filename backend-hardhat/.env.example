# Sepolia Testnet RPC endpoint
# Get your Alchemy RPC URL from https://www.alchemy.com/
SEPOLIA_ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key for MetaMask account to deploy contracts
# WARNING: Never commit your real private key to version control!
METAMASK_PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract verification
# Get your key from https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinMarketCap API key for gas reporter fiat conversion
# Get your key from https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Set to "true" to enable gas usage reports after test runs
REPORT_GAS_USAGE=false
